# Copia questo file in .env.local e compila i valori

# Sanity — trovi questi valori su manage.sanity.io dopo aver creato il progetto
NEXT_PUBLIC_SANITY_PROJECT_ID=il-tuo-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Token di sola lettura per il fetch dei dati (crea in manage.sanity.io > API > Tokens)
SANITY_API_READ_TOKEN=il-tuo-token

# Google Tag Manager (opzionale — aggiungi il tuo GTM-XXXXXX)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
